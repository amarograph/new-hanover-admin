{
  "rewrites": [
    { "source": "/api/auth/:action", "destination": "/api/auth?action=:action" },
    { "source": "/api/agenda/:id", "destination": "/api/agenda?slug=:id" },
    { "source": "/api/accounting/:id", "destination": "/api/accounting?slug=:id" },
    { "source": "/api/communiques/:id", "destination": "/api/communiques?slug=:id" },
    { "source": "/api/decrees/:id", "destination": "/api/decrees?slug=:id" },
    { "source": "/api/entreprises/:id", "destination": "/api/entreprises?slug=:id" },
    { "source": "/api/employes", "destination": "/api/entreprises?resource=employes" },
    { "source": "/api/employes/:id", "destination": "/api/entreprises?resource=employes&slug=:id" },
    { "source": "/api/taches", "destination": "/api/entreprises?resource=taches" },
    { "source": "/api/taches/:id", "destination": "/api/entreprises?resource=taches&slug=:id" },
    { "source": "/api/courriers", "destination": "/api/entreprises?resource=courriers" },
    { "source": "/api/courriers/:id", "destination": "/api/entreprises?resource=courriers&slug=:id" },
    { "source": "/api/boite-lettres", "destination": "/api/entreprises?resource=boite_lettres" },
    { "source": "/api/boite-lettres/:id", "destination": "/api/entreprises?resource=boite_lettres&slug=:id" },
    { "source": "/api/roles/:id", "destination": "/api/roles?slug=:id" },
    { "source": "/api/users/:id", "destination": "/api/users?slug=:id" }
  ]
}
