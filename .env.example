# Copiez ce fichier en .env (ou .env.local) pour le développement local avec `vercel dev`.
# En production, ces variables se configurent dans Vercel : Settings -> Environment Variables.

# Fournie automatiquement par Vercel si vous créez la base depuis Storage -> Postgres.
POSTGRES_URL=

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Identifiant(s) Discord (séparés par des virgules) automatiquement acceptés
# avec le rôle Administrateur principal lors de leur première connexion.
BOOTSTRAP_DISCORD_IDS=
